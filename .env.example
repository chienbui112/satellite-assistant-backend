# --- LLM provider switch ---
# One of: ollama | anthropic | openai | google | groq
LLM_PROVIDER=ollama
LLM_TEMPERATURE=0.1

# --- Ollama (local, default) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b-instruct
OLLAMA_NUM_CTX=8192

# --- Anthropic (Claude) ---
# Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- OpenAI (or OpenAI-compatible: Azure, OpenRouter, vLLM, etc.) ---
# Get a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Leave blank for openai.com; set for Azure / OpenRouter / self-hosted proxies.
OPENAI_BASE_URL=

# --- Google Gemini ---
# Get a key at https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=
GOOGLE_MODEL=gemini-2.0-flash

# --- Groq (fast hosted Llama / Qwen / Mixtral) ---
# Get a key at https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# --- STAC ---
STAC_API_URL=https://earth-search.aws.element84.com/v1
STAC_COLLECTION=sentinel-2-l2a
STAC_DEFAULT_LIMIT=10
STAC_MAX_LIMIT=50

# --- External commercial-provider aggregator ---
# POST endpoint that fronts Maxar / Planet / AxelGlobe.
# Default targets the geohub.vn relay; override to point elsewhere, or set
# to empty string to force mock mode (returns empty pages, no network call).
EXTERNAL_PROVIDER_URL=https://api.geohub.vn/v1/vmrs/api/v1/search
EXTERNAL_PROVIDER_API_KEY=
# Raw cookie string sent as the `Cookie` header on every aggregator call,
# e.g. "session=abc123; csrftoken=xyz". Leave empty if not required.
EXTERNAL_PROVIDER_COOKIE=
EXTERNAL_PROVIDER_PAGE_SIZE=10

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
LOG_LEVEL=INFO

# --- Geometry simplification ---
# Douglas-Peucker tolerance (degrees) applied to admin-boundary polygons
# before they ride in URL query strings, SSE payloads, or provider request
# bodies. Reference: 0.001°≈110m at the equator, 0.005°≈555m.
# Default 0.005 keeps Nominatim's Hà Nội polygon under ~12 KB URL-encoded
# (raw is 146 KB — would break nginx 8 KB request-line limit). Lower for
# higher precision; set to 0 to disable.
GEOMETRY_SIMPLIFY_TOLERANCE=0.005

# --- Conversation history window ---
# Number of *past* user-anchored turns of dialogue to send to the LLM each
# request. A turn = one user message + the assistant reply (and any tool
# messages in between).
#   - leave empty, omit, or set "none" / "null" → unlimited (full history)
#   - set a positive integer (e.g. 3) → keep only the last K turns
# Useful for staying under provider TPM limits when conversations get long.
CHAT_HISTORY_WINDOW_SIZE=

# --- Tokenizer (drives the UI's token-usage progress bar) ---
# transformers : exact, requires `pip install transformers` (large dep).
# tiktoken     : approximate, lightweight, already installed.
# char_count   : zero-dep fallback (len(text)//2).
TOKENIZER_METHOD=tiktoken
TOKENIZER_MODEL_NAME=Qwen/Qwen2.5-7B-Instruct

# Token budget for the UI's progress bar. Pick a value that matches your
# provider's TPM ceiling (Groq qwen3-32b free tier ≈ 6000).
MAX_TOKENS=6000
WARNING_THRESHOLD=4500
